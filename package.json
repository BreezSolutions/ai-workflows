{
  "name": "ai-workflows",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "predev": "lsof -ti:8080,5173 | xargs kill -9 2>/dev/null; true",
    "dev": "concurrently -n api,ui -c blue,magenta \"tsx watch src/index.ts\" \"cd frontend && npx vite --port 5173\"",
    "migrate-from-core-db": "tsx scripts/migrate-from-core-db.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.79.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "connect-mongo": "^6.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "googleapis": "^144.0.0",
    "jsdom": "^27.0.1",
    "mammoth": "^1.12.0",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-emoji": "^2.2.0",
    "officeparser": "^6.1.0",
    "p-limit": "^6.1.0",
    "pdf-lib": "^1.17.1",
    "satori": "^0.26.0",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
